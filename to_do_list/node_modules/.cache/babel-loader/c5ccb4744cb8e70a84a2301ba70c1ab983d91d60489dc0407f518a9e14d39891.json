{"ast":null,"code":"export default {\n  emits: [\"close\"],\n  methods: {\n    handleSubmit() {\n      console.log(\"Submitted\");\n    },\n    showIt() {\n      console.log(\"Data added\");\n    }\n  }\n};","map":{"version":3,"names":["emits","methods","handleSubmit","console","log","showIt"],"sources":["src/components/TodoElements/ShowModules.vue"],"sourcesContent":["<template>\n  <div id=\"overlay\">\n    <div id=\"divModule\" @click.stop>\n      <h2>Add To do List</h2>\n\n      <form @submit.prevent=\"handleSubmit\">\n        <input type=\"text\" placeholder=\"Enter your task here\" />\n      </form>\n\n      <br />\n      <div id=\"btns\">\n        <button>Add</button>\n        <button @click=\"$emit('close')\">Close</button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  emits: [\"close\"],\n\n  methods: {\n    handleSubmit() {\n      console.log(\"Submitted\");\n    },\n    showIt() {\n      console.log(\"Data added\");\n    },\n  },\n};\n</script>\n\n<style scoped>\n#overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.6);\n\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 999;\n}\n\n#divModule {\n  width: 600px;\n  height: 300px;\n  background: white;\n  border-radius: 10px;\n  padding-top: 50px;\n  margin-top: 50px;\n}\n\n#btns {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 20px;\n}\n</style>"],"mappings":"AAmBA;EACAA,KAAA;EAEAC,OAAA;IACAC,aAAA;MACAC,OAAA,CAAAC,GAAA;IACA;IACAC,OAAA;MACAF,OAAA,CAAAC,GAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}