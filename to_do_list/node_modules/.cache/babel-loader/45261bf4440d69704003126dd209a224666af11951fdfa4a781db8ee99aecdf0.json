{"ast":null,"code":"export default {\n  data() {\n    return {\n      task: \"\"\n    };\n  },\n  methods: {\n    handleSubmit() {\n      if (this.task !== \"\") {\n        this.$emit(\"save-task\", this.task);\n        this.task = \"\";\n      }\n    }\n  }\n};","map":{"version":3,"names":["data","task","methods","handleSubmit","$emit"],"sources":["src/components/TodoElements/ShowModules.vue"],"sourcesContent":["\n<template>\n  <div id=\"overlay\">\n    <div id=\"divModule\" @click.stop>\n      <h2>Add To do List</h2>\n\n      <form @submit.prevent=\"handleSubmit\">\n        <input type=\"text\" placeholder=\"Enter your task here\" v-model=\"task\" />\n\n        <br /><br />\n\n        <div id=\"btns\">\n          <button type=\"submit\">Add</button>\n          <button type=\"button\" @click=\"$emit('close')\">Close</button> \n          //here,it's parent is CreateBtn.vue and it used there.\n        </div>\n      </form>\n    </div> \n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      task: \"\",\n    };\n  },\n\n  methods: {\n    handleSubmit() {\n      if (this.task !== \"\") {\n        this.$emit(\"save-task\", this.task);\n        this.task = \"\";\n      }\n    },\n  },\n};\n</script>\n\n<style scoped>\n#overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.6);\n\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 999;\n}\n\n#divModule {\n  width: 600px;\n  height: 300px;\n  background: white;\n  border-radius: 10px;\n  padding-top: 50px;\n  margin-top: 50px;\n}\n\n#btns {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 20px;\n}\n</style>"],"mappings":"AAqBA;EACAA,KAAA;IACA;MACAC,IAAA;IACA;EACA;EAEAC,OAAA;IACAC,aAAA;MACA,SAAAF,IAAA;QACA,KAAAG,KAAA,mBAAAH,IAAA;QACA,KAAAA,IAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}