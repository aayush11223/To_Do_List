{"ast":null,"code":"import ShowModules from \"../ShowModules.vue\";\nexport default {\n  components: {\n    ShowModules\n  },\n  data() {\n    return {\n      msg: \"My To Do List\",\n      isModule: false\n    };\n  },\n  methods: {\n    showModuleForm() {\n      this.isModule = true;\n    },\n    saveTask(task) {\n      this.$emit(\"add-task\", task);\n      this.isModule = false;\n    }\n  }\n};","map":{"version":3,"names":["ShowModules","components","data","msg","isModule","methods","showModuleForm","saveTask","task","$emit"],"sources":["src/components/TodoElements/CreateBtn.vue"],"sourcesContent":["<template>\n  <div id=\"create\">\n    <h1>{{ msg }}</h1>\n\n    <button @click=\"showModuleForm()\">Create</button>\n\n    <ShowModules\n      v-if=\"isModule\"\n      @close=\"isModule = false\"\n      @save-task=\"saveTask\"\n    />\n  </div>\n</template>\n\n<script>\nimport ShowModules from \"../ShowModules.vue\";\n\nexport default {\n  components: { ShowModules },\n\n  data() {\n    return {\n      msg: \"My To Do List\",\n      isModule: false,\n    };\n  },\n\n  methods: {\n    showModuleForm() {\n      this.isModule = true;\n    },\n\n    saveTask(task) {\n      this.$emit(\"add-task\", task);\n      this.isModule = false;\n    },\n  },\n};\n</script>"],"mappings":"AAeA,OAAAA,WAAA;AAEA;EACAC,UAAA;IAAAD;EAAA;EAEAE,KAAA;IACA;MACAC,GAAA;MACAC,QAAA;IACA;EACA;EAEAC,OAAA;IACAC,eAAA;MACA,KAAAF,QAAA;IACA;IAEAG,SAAAC,IAAA;MACA,KAAAC,KAAA,aAAAD,IAAA;MACA,KAAAJ,QAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}