{"ast":null,"code":"export default {\n  data() {\n    return {\n      msg: 'My To Do List',\n      isModel: \"\"\n    };\n  },\n  // created() {\n  //     this.showModule()\n  // },\n  methods: {\n    showModule() {\n      this.isModel = \"abc\";\n      console.log(\"hello world\");\n    },\n    dontshowModule() {\n      this.isModel = false;\n    }\n  }\n};","map":{"version":3,"names":["data","msg","isModel","methods","showModule","console","log","dontshowModule"],"sources":["src/components/TodoElements/CreateBtn.vue"],"sourcesContent":["<template>\n    <div id=\"create\">\n        <h1>{{ msg }}</h1>\n        <template v-if=\"isModel\">\n            <button id=\"createBtn\" @click=\"dontshowModule()\">Create</button>\n        </template>\n        <template v-else-if=\"!isModel\">\n            <button id=\"cancelBtn\" @click=\"showModule()\">cancalBtn</button>\n        </template>\n\n\n\n        <template v-if=\"isModel === 'abc'\">\n            <div>\n                helloooo\n            </div>\n        </template>\n        <template v-else-if=\"isModel === 'bcd'\">\n            <div>\n                hiiii68\n            </div>\n        </template>\n        <template v-else>\n            <div>\n                baaal ho\n            </div>\n        </template>\n    </div>\n</template>\n\n<script>\nexport default {\n\n    data() {\n        return {\n\n            msg: 'My To Do List',\n            isModel: \"\",\n\n        }\n    },\n    // created() {\n    //     this.showModule()\n    // },\n    methods: {\n        showModule() {\n            this.isModel = \"abc\"\n            console.log(\"hello world\")\n        },\n        dontshowModule() {\n            this.isModel = false\n        }\n    }\n}\n</script>\n\n<style lang=\"scss\" scoped></style>"],"mappings":"AA+BA;EAEAA,KAAA;IACA;MAEAC,GAAA;MACAC,OAAA;IAEA;EACA;EACA;EACA;EACA;EACAC,OAAA;IACAC,WAAA;MACA,KAAAF,OAAA;MACAG,OAAA,CAAAC,GAAA;IACA;IACAC,eAAA;MACA,KAAAL,OAAA;IACA;EACA;AACA","ignoreList":[]},"metadata