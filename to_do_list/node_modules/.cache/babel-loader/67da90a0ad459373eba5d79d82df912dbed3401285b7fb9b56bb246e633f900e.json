{"ast":null,"code":"import ShowModules from \"./ShowModules.vue\";\nexport default {\n  components: {\n    ShowModules\n  },\n  data() {\n    return {\n      msg: \"My To Do List\",\n      isModule: false\n    };\n  },\n  methods: {\n    showModule() {\n      this.isModule = true;\n    },\n    saveTask() {\n      this.isModule = false;\n    }\n  }\n};","map":{"version":3,"names":["ShowModules","components","data","msg","isModule","methods","showModule","saveTask"],"sources":["src/components/TodoElements/CreateBtn.vue"],"sourcesContent":["\n<template>\n  <div id=\"create\">\n    <h1>{{ msg }}</h1>\n\n    <button @click=\"showModule\">Create</button>\n\n    <ShowModules\n      v-if=\"isModule\"\n      @close=\"isModule = false\"\n      @save-task=\"saveTask\"\n    />\n  </div>\n</template>\n\n<script>\nimport ShowModules from \"./ShowModules.vue\";\n\nexport default {\n  components: {\n    ShowModules,\n  },\n\n  data() {\n    return {\n      msg: \"My To Do List\",\n      isModule: false,\n    };\n  },\n\n  methods: {\n    showModule() {\n      this.isModule = true;\n    },\n    saveTask() {\n      this.isModule = false;\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped></style>"],"mappings":"AAgBA,OAAAA,WAAA;AAEA;EACAC,UAAA;IACAD;EACA;EAEAE,KAAA;IACA;MACAC,GAAA;MACAC,QAAA;IACA;EACA;EAEAC,OAAA;IACAC,WAAA;MACA,KAAAF,QAAA;IACA;IACAG,SAAA;MACA,KAAAH,QAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}